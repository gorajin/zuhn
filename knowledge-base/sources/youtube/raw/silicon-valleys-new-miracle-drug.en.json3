  }, {
    "tStartMs": 254520,
    "dDurationMs": 868,
    "segs": [ {
      "utf8": "what do you got for me?"
    } ]
  }, {
    "tStartMs": 255388,
    "dDurationMs": 3237,
    "segs": [ {
      "utf8": "They basically were like, well,\nwe have this thing called NAD for you."
    } ]
  }, {
    "tStartMs": 259092,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "The med spa's generally are"
    } ]
  }, {
    "tStartMs": 261661,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "limited to what they can legally obtain."
    } ]
  }, {
    "tStartMs": 264764,
    "dDurationMs": 4404,
    "segs": [ {
      "utf8": "Then I was like, well, let me go through\nthe sort of other channel that people are,"
    } ]
  }, {
    "tStartMs": 269535,
    "dDurationMs": 3904,
    "segs": [ {
      "utf8": "you know, engaging in with this stuff,\nwhich is what you're seeing more"
