  }, {
    "tStartMs": 328328,
    "dDurationMs": 3203,
    "segs": [ {
      "utf8": "It's a place to build a real portfolio,\none for the long haul."
    } ]
  }, {
    "tStartMs": 331564,
    "dDurationMs": 5105,
    "segs": [ {
      "utf8": "We're talking stocks, ETFs, bonds,\noptions, crypto, treasuries, you name it."
    } ]
  }, {
    "tStartMs": 336669,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "You name it, you name it. You know what?"
