  }, {
    "tStartMs": 783916,
    "dDurationMs": 2469,
    "segs": [ {
      "utf8": "and it certainly sucks to hear\nabout all these things"
    } ]
  }, {
    "tStartMs": 786385,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "you and these sexless men are going\nthrough."
