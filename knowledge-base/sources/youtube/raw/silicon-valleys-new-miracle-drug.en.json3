  }, {
    "tStartMs": 743609,
    "dDurationMs": 3036,
    "segs": [ {
      "utf8": "aphorism of the future is already here,\nbut not evenly distributed."
    } ]
  }, {
    "tStartMs": 746645,
    "dDurationMs": 3871,
    "segs": [ {
      "utf8": "And I think many of the smartest people\nI know, many of the smartest biologists"
    } ]
  }, {
    "tStartMs": 750516,
    "dDurationMs": 3403,
    "segs": [ {
      "utf8": "I know, and doctors I know are using\npeptides are familiar with peptides."
    } ]
  }, {
    "tStartMs": 753919,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "Now, there are risks."
    } ]
  }, {
    "tStartMs": 754920,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "I don't recommend people\nblindly take peptides."
    } ]
  }, {
    "tStartMs": 757189,
    "dDurationMs": 3704,
    "segs": [ {
      "utf8": "I certainly don't recommend they order\nthem from research use only sites online."
    } ]
  }, {
    "tStartMs": 760893,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "I think if you have the foundations\nof health in check,"
    } ]
  }, {
    "tStartMs": 763863,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "that should be the default for everyone."
    } ]
  }, {
    "tStartMs": 765965,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "That's what men used to be like\nand now the modern world"
    } ]
  }, {
    "tStartMs": 769001,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "makes that really hard"
    } ]
  }, {
    "tStartMs": 770469,
    "dDurationMs": 3771,
    "segs": [ {
      "utf8": "because we're surrounded by a lot of\nthings that impact our sex hormones"
    } ]
  }, {
    "tStartMs": 774240,
    "dDurationMs": 3036,
    "segs": [ {
      "utf8": "and our endocrine system in a negative way."
