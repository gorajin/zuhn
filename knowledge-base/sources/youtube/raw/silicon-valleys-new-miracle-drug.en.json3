  }, {
    "tStartMs": 585518,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "And I said, that's insane."
    } ]
  }, {
    "tStartMs": 587520,
    "dDurationMs": 3870,
    "segs": [ {
      "utf8": "So I called my friend\nand instead of going through the pharmacy"
