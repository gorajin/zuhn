  }, {
    "tStartMs": 671737,
    "dDurationMs": 1135,
    "segs": [ {
      "utf8": "I get it,"
    } ]
  }, {
    "tStartMs": 672872,
    "dDurationMs": 3303,
    "segs": [ {
      "utf8": "I'm a guy who likes to keep his blood\nclean in case anyone needs to drink it."
