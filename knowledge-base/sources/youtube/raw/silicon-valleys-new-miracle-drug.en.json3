  }, {
    "tStartMs": 834600,
    "dDurationMs": 3403,
    "segs": [ {
      "utf8": "We need us. Tonight."
    } ]
  }, {
    "tStartMs": 838904,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "Now and forever."
    } ]
  }, {
    "tStartMs": 844009,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "And if none of that works"
    } ]
  }, {
    "tStartMs": 845611,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "Just maybe try some peptides."
    } ]
  }, {
    "tStartMs": 847346,
    "dDurationMs": 3871,
    "segs": [ {
      "utf8": "Yeah, well,\nI couldn't be more against this BS."
    } ]
  }, {
    "tStartMs": 851483,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "Okay. Who's this fun sucker?"
    } ]
  }, {
    "tStartMs": 852918,
    "dDurationMs": 3037,
    "segs": [ {
      "utf8": "Eric Topol is a cardiologist\nand director of the Scripps"
    } ]
  }, {
    "tStartMs": 855955,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Research Translational Institute."
    } ]
  }, {
    "tStartMs": 857790,
    "dDurationMs": 901,
    "segs": [ {
      "utf8": "He's also the author"
    } ]
  }, {
    "tStartMs": 858691,
    "dDurationMs": 3803,
    "segs": [ {
      "utf8": "of multiple New York Times bestsellers,\nas well as the Ground Truths newsletter,"
    } ]
  }, {
    "tStartMs": 862494,
    "dDurationMs": 668,
    "segs": [ {
      "utf8": "where he covers"
    } ]
