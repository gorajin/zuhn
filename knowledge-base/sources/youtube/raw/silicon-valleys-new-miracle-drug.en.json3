    } ]
  }, {
    "tStartMs": 359459,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "invest it with real money, the whole kit\nand caboodle. Kit and caboodle?"
    } ]
  }, {
    "tStartMs": 363196,
    "dDurationMs": 2135,
    "segs": [ {
      "utf8": "Yeah, it's a whole thing.\nGo to public.com slash"
    } ]
  }, {
    "tStartMs": 365331,
    "dDurationMs": 1402,
    "segs": [ {
      "utf8": "goodwork to sign up. Public"
    } ]
  }, {
    "tStartMs": 366733,
    "dDurationMs": 4304,
    "segs": [ {
      "utf8": "will even give you an uncapped\n1% match when you transfer your portfolio"
    } ]
  }, {
    "tStartMs": 371170,
    "dDurationMs": 2469,
    "segs": [ {
      "utf8": "from another brokerage.\nThat's public.com slash"
    } ]
  }, {
    "tStartMs": 373639,
    "dDurationMs": 601,
    "segs": [ {
      "utf8": "goodwork"
    } ]
  }, {
    "tStartMs": 374240,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "Thanks very much to our friends at Public\nfor sponsoring this video."
    } ]
  }, {
    "tStartMs": 378077,
    "dDurationMs": 3370,
    "segs": [ {
      "utf8": "Now, the vast majority of peptides\nthat are being hawked on the Tok"
    } ]
  }, {
    "tStartMs": 381447,
    "dDurationMs": 3404,
    "segs": [ {
      "utf8": "are not federally regulated\nand have been listed by the FDA"
    } ]
  }, {
    "tStartMs": 384851,
    "dDurationMs": 3370,
    "segs": [ {
