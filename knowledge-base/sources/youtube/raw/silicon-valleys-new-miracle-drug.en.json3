  }, {
    "tStartMs": 878677,
    "dDurationMs": 4038,
    "segs": [ {
      "utf8": "and promotion and longevity clinics\nand that kind of stuff."
    } ]
  }, {
    "tStartMs": 882748,
    "dDurationMs": 3604,
    "segs": [ {
      "utf8": "When we inject a drug in our body,\nwe should know"
