  }, {
    "tStartMs": 886719,
    "dDurationMs": 3603,
    "segs": [ {
      "utf8": "that it's safe, that it is\nwhat it says it is and it's effective."
    } ]
  }, {
    "tStartMs": 890322,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "That only can be done\nthrough clinical trials."
