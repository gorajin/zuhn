  }, {
    "tStartMs": 919251,
    "dDurationMs": 2136,
    "segs": [ {
      "utf8": "And I don't-\nI don't care about the pushback."
    } ]
  }, {
    "tStartMs": 921387,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "I'm just telling the truth."
    } ]
  }, {
    "tStartMs": 923088,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "I'm given the facts."
    } ]
  }, {
    "tStartMs": 925090,
    "dDurationMs": 3204,
    "segs": [ {
      "utf8": "Now folks, when Instagram told me to get on threads,\nI said f*ck that sh*t."
    } ]
  }, {
    "tStartMs": 928294,
    "dDurationMs": 4404,
    "segs": [ {
      "utf8": "But in an age of rising tech skepticism,\npeptides seem to be a rare moment"
    } ]
  }, {
    "tStartMs": 932698,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "of a Silicon Valley trend bleeding out\ninto the general public."
    } ]
  }, {
    "tStartMs": 936368,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "Hearing the range of people for whom\nthis is very appealing,"
    } ]
  }, {
    "tStartMs": 939738,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "made me think that, like, yeah,\nthis is going to be a huge thing."
    } ]
  }, {
    "tStartMs": 942541,
    "dDurationMs": 3771,
