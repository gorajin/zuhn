  }, {
    "tStartMs": 689822,
    "dDurationMs": 3403,
    "segs": [ {
      "utf8": "I work hard, I don't sleep enough,\nI push my body."
    } ]
  }, {
    "tStartMs": 693759,
    "dDurationMs": 3671,
    "segs": [ {
      "utf8": "Now, if I'm about to get sick, I inject\n[name of a peptide??], and I don't get sick."
    } ]
  }, {
    "tStartMs": 697430,
    "dDurationMs": 3803,
    "segs": [ {
      "utf8": "Max Marchione is the co-founder\nof the Health startup Superpower."
